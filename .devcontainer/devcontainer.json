{
  "name": "polars-db",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },
  "remoteUser": "user",
  "workspaceFolder": "/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/user/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/user/.claude.json,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/user/.ssh,type=bind,readonly"
  ],
  "postCreateCommand": "uv sync --all-groups && uv run pre-commit install"
}
